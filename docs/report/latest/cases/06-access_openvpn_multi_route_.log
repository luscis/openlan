header  : verify sw1 network a openvpn client reaches sw2 network a and b addresses
topology: vpn1@sw1/a 10.82.0.10 | sw1 a 192.82.0.1 -- TCP output --> sw2 a 192.82.0.2 + sw2 b 192.83.0.2
topology: # Topology:
topology: # - Diagram:
topology: #       vpn1@a 10.82.0.10
topology: #              |
topology: #       sw1 network a 192.82.0.1
topology: #              |
topology: #              | TCP output
topology: #              v
topology: #       sw2 network a 192.82.0.2
topology: #       sw2 network b 192.83.0.2
topology: # - Docker mgmt network: 100.100.0.0/24
topology: #   sw1=100.100.0.241, sw2=100.100.0.242, vpn1 joins the same mgmt network.
topology: # - OpenLAN service networks:
topology: #   network a: sw1=192.82.0.1/24, sw2=192.82.0.2/24.
topology: #   network b: sw2=192.83.0.2/24.
topology: # - OpenVPN overlay:
topology: #   sw1 network a tcp/1194, subnet 10.82.0.0/24, vpn1@a fixed address 10.82.0.10.
topology: # - Routing:
topology: #   sw1/a routes sw2/a and sw2/b subnets via sw2/a; sw2/a routes the OpenVPN subnet back via sw1/a.
topology: # Validation:
topology: #   The OpenVPN client connected to sw1 network a can reach both sw2 network a
topology: #   and sw2 network b addresses.

