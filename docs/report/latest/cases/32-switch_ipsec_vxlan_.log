topology: # - Output link:
topology: #   sw2 -> sw1 by vxlan output.
topology: # Validation:
topology: #   sw2 can ping/perf to sw1 on plain vxlan output (no ipsec tunnel),
topology: #   then repeat ping/perf after enabling ipsec tunnel on the same path.

