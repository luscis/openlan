topology: #   network int: 192.55.0.1/24 (uplink to sw2)
topology: #   network a: 192.53.0.1/24 (with OpenVPN subnet 10.95.0.0/24)
topology: #   network b: 192.54.0.1/24
topology: # - sw2 virtual network:
topology: #   network int: 192.55.0.2/24, loopback subnet target 10.253.0.12/32.
topology: # Validation:
topology: #   default: all networks snat disabled, including int.
topology: #   scope openvpn: a.openvpn yes, a.access no, b.openvpn no, b.access no.
topology: #   scope local:   a.openvpn yes, a.access yes, b.openvpn no, b.access no.
topology: #   scope enable:  a.openvpn yes, a.access yes, b.openvpn yes, b.access yes.

