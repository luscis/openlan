topology: # Topology:
topology: # - Diagram:
topology: #       vpn/access on sw1 network a,b
topology: #                 |
topology: #       sw1: a=192.53.0.1 b=192.54.0.1 int=192.55.0.1
topology: #                 | int output uplink
topology: #       sw2: int=192.55.0.2, target VIP 10.253.0.12
topology: #                 SNAT scopes: disabled, openvpn, local, enable
topology: # - Docker mgmt network: 172.249.0.0/24
topology: #   sw1=172.249.0.241, sw2=172.249.0.242.
